PORT=3000
HOST=0.0.0.0

# Optional shared secret. If set, protected API routes require ?token=... or x-api-token.
API_TOKEN=

# Public origin used when absolute audio URLs are requested. Leave empty for relative URLs.
PUBLIC_BASE_URL=

# OpenAI is required for speech-to-text, text-to-speech, and optional LLM helpers.
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_QUERY_MODEL=gpt-4.1-nano
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Local storage.
DATA_DIR=./data
GENERATED_AUDIO_DIR=./generated-audio
GENERATED_AUDIO_TTL_HOURS=24
MAX_AUDIO_BYTES=8388608
ENABLE_RECIPE_LLM_COERCION=
DEBUG_QUERY=0
